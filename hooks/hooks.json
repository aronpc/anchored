{
  "description": "Anchored hooks — SessionStart injects the full persistent-memory routing block; UserPromptSubmit runs intent-aware auto-recall (top memories + recent artifacts) within a token budget; PostToolUse captures state-changing tool events and indexes large outputs as searchable artifacts; PreCompact snapshots the conversation; PreToolUse blocks dangerous code inside anchored sandbox tools and blocks writing a secret into shared memory/instruction files.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook sessionstart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook userpromptsubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Read|Grep|Glob|Bash|WebFetch|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook pretooluse"
          }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|mcp__anchored__",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook posttooluse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook precompact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook stop"
          }
        ]
      }
    ]
  }
}
