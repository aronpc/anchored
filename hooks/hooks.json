{
  "description": "Anchored hooks — SessionStart injects the full persistent-memory routing block; UserPromptSubmit injects a compact reminder plus always-on BM25 pre-search hits; PostToolUse captures state-changing tool events; PreCompact snapshots the conversation; PreToolUse blocks dangerous code inside anchored sandbox tools.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook sessionstart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook userpromptsubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__anchored__anchored_execute|mcp__anchored__anchored_execute_file|mcp__anchored__anchored_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|mcp__anchored__",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook posttooluse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "anchored hook precompact"
          }
        ]
      }
    ]
  }
}
