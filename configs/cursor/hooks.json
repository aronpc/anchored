{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "matcher": "Shell|Read|Grep|WebFetch|MCP:anchored_save|MCP:anchored_search|MCP:anchored_kg_query|MCP:anchored_kg_add",
        "command": "anchored hook pretooluse"
      }
    ],
    "postToolUse": [
      {
        "command": "anchored hook posttooluse"
      }
    ],
    "stop": [
      {
        "command": "anchored hook precompact"
      }
    ]
  }
}
